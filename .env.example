# LiteLLM Proxy base URL. Do not include /v1; the app appends it automatically.
LITELLM_BASE_URL=http://localhost:4000

# Optional if your LiteLLM Proxy does not require auth.
LITELLM_API_KEY=

# Optional when each request provides a model.
LITELLM_DEFAULT_MODEL=

# Optional model used for NSFW-enabled LLM-backed operations.
# Falls back to the purpose-specific/default model when omitted.
LITELLM_NSFW_MODEL=

# Show the main editor NSFW toggle button. Defaults to false.
SCENEFORGE_SHOW_NSFW_BUTTON=false

# Optional model used only for prompt-library AI classification.
# Falls back to LITELLM_DEFAULT_MODEL when omitted.
LITELLM_CLASSIFICATION_MODEL=

# Optional model used only for Civitai checkpoint + LoRA combination recommendations.
# Falls back to LITELLM_DEFAULT_MODEL when omitted.
LITELLM_CIVITAI_RECOMMENDATION_MODEL=

# Optional model used only for ComfyUI generated image diagnosis.
# Falls back to LITELLM_DEFAULT_MODEL when omitted.
LITELLM_COMFYUI_DIAGNOSIS_MODEL=

# Optional local LLM request/response log file. Set to "off" to disable local LLM logging.
# Defaults to <repo>/data/logs/llm-chat.jsonl when unset.
# SCENEFORGE_LLM_LOG_FILE=

# Optional Tavily web search credentials for ComfyUI diagnosis web context.
TAVILY_API_KEY=
TAVILY_BASE_URL=https://api.tavily.com

# Optional Civitai API key used for authenticated model downloads.
CIVITAI_API_KEY=

# Local ComfyUI server base URL.
COMFYUI_BASE_URL=http://127.0.0.1:8188

# Optional if your ComfyUI server/proxy requires auth.
COMFYUI_API_KEY=

# Optional absolute path to the local ComfyUI temp directory.
# Required if you want SceneForge to truly delete unsaved PreviewImage files.
# COMFYUI_TEMP_DIR=

# Optional absolute path where SceneForge stores generated images after clicking Save.
# Defaults to <repo>/data/comfyui-generated-images when unset.
# SCENEFORGE_GENERATED_IMAGES_DIR=

# Optional absolute path where SceneForge stores ComfyUI sequence reference images.
# Defaults to <repo>/data/comfyui-sequence-references when unset.
# SCENEFORGE_SEQUENCE_REFERENCE_DIR=

# Optional absolute path where SceneForge stores project JSON files via the Next.js API.
# Defaults to <repo>/data/projects when unset.
# SCENEFORGE_PROJECTS_DIR=

# Optional absolute path to the local SQLite database for settings and Civitai metadata.
# Defaults to <repo>/data/sceneforge.sqlite when unset.
# Run `npm run civitai:reindex` after changing imported Civitai resources so BM25 recommendations can use the derived FTS index.
# SCENEFORGE_SQLITE_FILE=

# Optional absolute path to the shared prompt library JSON (custom tags + hidden built-in ids).
# Defaults to <repo>/data/prompt-library.json when unset.
# SCENEFORGE_PROMPT_LIBRARY_FILE=
